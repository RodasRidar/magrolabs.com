{
  "version": 2,
  "builds": [
    { "src": "api/flow/*/*.ts", "use": "@vercel/node" },
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/flow/$1",
      "headers": { "Cache-Control": "s-maxage=31536000, immutable" }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": { "Cache-Control": "s-maxage=31536000, immutable" }
    }
  ],
  "functions": {
    "api/flow/*/*.ts": {
      "runtime": "nodejs18.x"
    }
  },
  "framework": "angular"
}
