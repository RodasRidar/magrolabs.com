{
  "version": 2,
  "builds": [
    {
      "src": "dist/magrolabs-app/server/server.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "dist/magrolabs-app/browser/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/magrolabs-app/server/server.mjs"
    }
  ]
}
